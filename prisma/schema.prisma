generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Platform / Multi-Tenant Models ──

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  address     String?
  phone       String?
  email       String?
  website     String?
  plan        String   @default("basic")       // basic, standard, premium, enterprise
  status      String   @default("active")       // active, suspended, trial, inactive
  maxStudents Int      @default(100)
  maxTeachers Int      @default(20)
  maxParents  Int      @default(100)
  maxClasses  Int      @default(10)
  settings    String   @default("{}")           // JSON settings
  startDate   String
  endDate     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  classes        Class[]
  notices        Notice[]
  events         Event[]
  subscriptions  Subscription[]
  auditLogs      AuditLog[]
  customRoles    CustomRole[]
  tickets        Ticket[]

  @@index([status])
  @@index([plan])
  @@index([createdAt])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  resource  String
  details   String   @default("{}")
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([action])
  @@index([createdAt])
}

// ── Core User Model ──

model User {
  id            String        @id @default(cuid())
  tenantId      String?
  email         String        @unique
  name          String
  password      String
  role          String        @default("student")  // super_admin, admin, teacher, student, parent, staff
  phone         String?
  address       String?
  avatar        String?
  isActive      Boolean       @default(true)
  customRoleId  String?
  platformRoleId String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant        Tenant?         @relation(fields: [tenantId], references: [id])
  customRole    CustomRole?     @relation(fields: [customRoleId], references: [id])
  platformRole  PlatformRole?   @relation(fields: [platformRoleId], references: [id])
  student       Student?
  teacher       Teacher?
  parent        Parent?
  notices       Notice[]
  createdTickets    Ticket[]     @relation("TicketCreator")
  assignedTickets   Ticket[]     @relation("TicketAssignee")
  ticketMessages    TicketMessage[] @relation("TicketMessageAuthor")

  @@index([tenantId])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model Student {
  id            String   @id @default(cuid())
  userId        String   @unique
  rollNumber    String
  classId       String
  parentId      String?
  dateOfBirth   String?
  gender        String   @default("male")
  bloodGroup    String?
  admissionDate String   @default("2024-04-01")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  class       Class     @relation(fields: [classId], references: [id])
  parent      Parent?   @relation(fields: [parentId], references: [id])
  attendance  Attendance[]
  grades      Grade[]
  submissions Submission[]
  fees        Fee[]

  @@index([classId])
  @@index([parentId])
  @@index([gender])
}

model Teacher {
  id           String   @id @default(cuid())
  userId       String   @unique
  qualification String?
  experience   String?
  joiningDate  String   @default("2024-04-01")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user        User           @relation(fields: [userId], references: [id])
  classes     ClassTeacher[]
  subjects    Subject[]
  assignments Assignment[]
  grades      Grade[]
  timetable   Timetable[]
}

model Parent {
  id        String   @id @default(cuid())
  userId    String   @unique
  occupation String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User           @relation(fields: [userId], references: [id])
  students     Student[]
  subscriptions Subscription[]
}

model Class {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  section   String   @default("A")
  grade     String
  capacity  Int      @default(40)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  students    Student[]
  teachers    ClassTeacher[]
  subjects    Subject[]
  timetable   Timetable[]
  attendance  Attendance[]
  assignments Assignment[]

  @@index([tenantId])
  @@index([grade])
}

model ClassTeacher {
  id           String   @id @default(cuid())
  classId      String
  teacherId    String
  isClassTeacher Boolean @default(false)
  createdAt    DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([classId, teacherId])
  @@index([teacherId])
}

model Subject {
  id        String   @id @default(cuid())
  name      String
  code      String
  classId   String
  teacherId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class       Class       @relation(fields: [classId], references: [id])
  teacher     Teacher?    @relation(fields: [teacherId], references: [id])
  grades      Grade[]
  assignments Assignment[]
  timetable   Timetable[]

  @@index([classId])
  @@index([teacherId])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  classId   String
  date      String
  status    String   @default("present")
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id])
  class   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, classId, date])
  @@index([studentId])
  @@index([classId])
  @@index([date])
  @@index([status])
  @@index([classId, date, status])  // ⚡ Composite for dashboard attendance queries
}

model Grade {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  teacherId String
  examType  String
  marks     Float
  maxMarks  Float
  grade     String?
  remarks   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([studentId])
  @@index([subjectId])
  @@index([teacherId])
  @@index([examType])
}

model Assignment {
  id          String   @id @default(cuid())
  subjectId   String
  classId     String
  teacherId   String
  title       String
  description String?
  dueDate     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject     @relation(fields: [subjectId], references: [id])
  class       Class       @relation(fields: [classId], references: [id])
  teacher     Teacher     @relation(fields: [teacherId], references: [id])
  submissions Submission[]

  @@index([classId])
  @@index([teacherId])
  @@index([dueDate])
}

model Submission {
  id           String   @id @default(cuid())
  assignmentId String
  studentId    String
  content      String?
  status       String   @default("submitted")
  submittedAt  DateTime @default(now())
  grade        String?
  feedback     String?

  assignment Assignment @relation(fields: [assignmentId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])

  @@index([assignmentId])
  @@index([studentId])
  @@index([status])
}

model Fee {
  id         String   @id @default(cuid())
  studentId  String
  amount     Float
  type       String
  status     String   @default("pending")
  dueDate    String
  paidDate   String?
  paidAmount Float    @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([status])
  @@index([type])
  @@index([dueDate])
  @@index([studentId, type, status])  // ⚡ Composite for fee aggregation queries
}

model Notice {
  id         String   @id @default(cuid())
  tenantId   String
  title      String
  content    String
  authorId   String
  targetRole String   @default("all")
  priority   String   @default("normal")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([tenantId])
  @@index([targetRole])
  @@index([priority])
  @@index([createdAt])
}

model Timetable {
  id        String   @id @default(cuid())
  classId   String
  subjectId String
  teacherId String
  day       String
  startTime String
  endTime   String
  createdAt DateTime @default(now())

  class   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@index([classId])
  @@index([teacherId])
  @@index([day])
}

model Event {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  description String?
  date        String
  endDate     String?
  type        String   @default("general")    // exam, holiday, event, meeting, sports, cultural, deadline, other
  targetRole  String   @default("all")        // all, admin, teacher, student, parent
  color       String   @default("#10b981")    // hex color
  allDay      Boolean  @default(false)
  location    String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([date])
  @@index([type])
  @@index([targetRole])
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String
  parentId        String
  planName        String
  planId          String
  amount          Float
  period          String   @default("yearly")
  status          String   @default("active")
  paymentMethod   String   @default("card")
  transactionId   String?
  startDate       String
  endDate         String?
  autoRenew       Boolean  @default(true)
  addons          String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  parent Parent @relation(fields: [parentId], references: [id])

  @@index([tenantId])
  @@index([parentId])
  @@index([status])
  @@index([planId])
  @@index([createdAt])
  @@index([tenantId, status, planName])  // ⚡ Composite for billing queries
}

// ── Platform Roles (Super Admin Level) ──

model PlatformRole {
  id          String   @id @default(cuid())
  name        String                           // e.g. "Support Agent", "Billing Manager"
  description String?
  color       String   @default("#e11d48")
  permissions String   @default("{}")           // JSON: { "tenants": ["view","create"], "billing": ["view"], ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@index([name])
}

// ── Ticketing System ──

model Ticket {
  id          String   @id @default(cuid())
  tenantId    String?
  title       String
  description String
  status      String   @default("open")       // open, in_progress, on_hold, resolved, closed
  priority    String   @default("medium")      // low, medium, high, urgent
  category    String   @default("general")     // general, billing, technical, academics, feature_request, complaint, other
  createdBy   String
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant?         @relation(fields: [tenantId], references: [id])
  creator     User            @relation("TicketCreator", fields: [createdBy], references: [id])
  assignee    User?           @relation("TicketAssignee", fields: [assignedTo], references: [id])
  messages    TicketMessage[]

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdBy])
  @@index([assignedTo])
  @@index([createdAt])
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  message   String
  createdAt DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author    User     @relation("TicketMessageAuthor", fields: [userId], references: [id])

  @@index([ticketId])
  @@index([userId])
  @@index([createdAt])
}

// ── Platform Settings (Key-Value Store) ──

model PlatformSetting {
  key       String   @id                           // e.g. "maintenance_mode"
  value     String   @default("false")              // JSON or plain value
  updatedAt DateTime @updatedAt

  @@index([key])
}

// ── Custom Roles & Permissions ──

model CustomRole {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // e.g. "Finance Manager", "Librarian", "Sports Coordinator"
  description String?
  color       String   @default("#6366f1")  // hex color for UI
  permissions String   @default("{}")       // JSON: { "students": ["view"], "fees": ["view","create","edit"], ... }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  users   User[]

  @@index([tenantId])
  @@index([name])
}
